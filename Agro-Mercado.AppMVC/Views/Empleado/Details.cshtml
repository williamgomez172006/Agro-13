@model Agro_Mercado.AppMVC.Models.Empleado

<h2>Detalle de Empleado</h2>

<div class="card mt-3">
    <div class="card-body">

        <p><strong>Nombre:</strong> @Model.Nombre</p>
        <p><strong>Correo:</strong> @Model.Correo</p>
        <p><strong>Rol:</strong> @Model.Rol?.Nombre</p>
        <p><strong>Estado:</strong> @(Model.Activo ? "Activo" : "Inactivo")</p>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                Editar
            </a>

            <a asp-action="Index" class="btn btn-secondary">
                Volver
            </a>
        </div>

    </div>
</div>