@inject Agro_Mercado.AppMVC.Models.AgroMercadoSprintContext _context

@{
    var datosNegocio = _context.DatosNegocios.FirstOrDefault();
}
@{
    var rolId = Context.Session.GetInt32("RolId");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Agromercado.AppMVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Agromercado.AppMVC.styles.css" asp-append-version="true" />
    <style>
        /* ESTRUCTURA CORREGIDA PARA FOOTER ABAJO */
        html {
            height: 100%;
        }

        body {
            min-height: 100vh;
            background-color: #f4f1ea;
            margin: 0;
            display: flex;
            flex-direction: column;
        }

        main {
            background-color: white;
            padding: 25px;
            padding-bottom: 120px;
            border-radius: 12px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.08);
            flex: 1;
        }

        footer {
            background: linear-gradient(90deg, #2e7d32, #4caf50);
            color: white !important;
            padding: 15px 0;
            margin-top: 80px;
        }

            footer a {
                color: #ffeb3b !important;
                text-decoration: none;
            }

        /* NAVBAR ESTILO AGRO */
        .navbar {
            background: linear-gradient(90deg, #2e7d32, #4caf50) !important;
        }

            .navbar .nav-link,
            .navbar-brand {
                color: white !important;
                font-weight: 500;
            }

                .navbar .nav-link:hover {
                    color: #ffeb3b !important;
                    transition: 0.3s;
                }

        /* CONTENIDO */

        h1, h2, h3 {
            color: #2e7d32;
            font-weight: bold;
        }

        /* BOTONES */
        .btn-success {
            background-color: #2e7d32;
            border: none;
        }

            .btn-success:hover {
                background-color: #1b5e20;
            }

        .btn-danger {
            background-color: #c62828;
            border: none;
        }

            .btn-danger:hover {
                background-color: #8e0000;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">🌾 AgroMercado </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>


                        @if (rolId == 1)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Empleado" asp-action="Index">
                                    Empleados
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="DatosNegocio" asp-action="Index">
                                    Configuración
                                </a>
                            </li>
                        }
                        @if (rolId == 1 || rolId == 6 || rolId == 8)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="UnidadesMedida" asp-action="Index">
                                    Unidades de Medida
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Categorias" asp-action="Index">
                                    Categorías
                                </a>
                            </li>
                        }
                        @if (rolId == 1)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Role" asp-action="Index">
                                    Rol
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Producto" asp-action="Index">
                                    Producto
                                </a>
                            </li>
                        }
                        @if (Context.Session.GetString("Usuario") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                                    Cerrar Sesión
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-3">

        <main role="main">
            @RenderBody()
        </main>

        <footer class="border-top text-muted">
            <div class="container">
                &copy; 2026 - Agromercado.AppMVC -
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>

    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>