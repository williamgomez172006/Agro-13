@model LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}
    
<style>
    /* NO tocar el body del layout */
    body {
        background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1500382017468-9049fed747ef');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    /* Contenedor centrado SIN romper el layout */
    .login-container {
        min-height: calc(85vh - 120px); /* resta aproximada del header + footer */
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 0;
    }

    .login-card {
        background: white;
        padding: 40px;
        border-radius: 15px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .login-title {
        text-align: center;
        color: #2e7d32;
        font-weight: bold;
        margin-bottom: 25px;
    }

    .form-control {
        border-radius: 8px;
    }

    .btn-login {
        background-color: #2e7d32;
        color: white;
        width: 100%;
        border-radius: 8px;
        font-weight: 500;
    }

        .btn-login:hover {
            background-color: #1b5e20;
        }

    .error-text {
        color: red;
        text-align: center;
        margin-top: 10px;
    }
</style>

<div class="login-container">
    <div class="login-card">

        <h3 class="login-title">🌾 AgroMercado</h3>

        <form asp-action="Login" method="post">

            <div class="mb-3">
                <label class="form-label">Correo</label>
                <input asp-for="Correo" class="form-control" />
                <span asp-validation-for="Correo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-login">
                Ingresar
            </button>

            @if (ViewBag.Error != null)
            {
                <p class="error-text">@ViewBag.Error</p>
            }

        </form>

    </div>
</div>