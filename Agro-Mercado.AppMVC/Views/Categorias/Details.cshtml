@model Agro_Mercado.AppMVC.Models.Categoria

<h2>Detalle Categoría</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Nombre:</strong> @Model.Nombre</p>
        <p><strong>Descripción:</strong> @Model.Descripcion</p>
        <p><strong>Estado:</strong> @(Model.Estado ? "Activa" : "Inactiva")</p>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</div>